{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "name": "overview",
  "version": 1,
  "description": "Machine-readable manifest for AI agents, MCP servers, and RAG indexers working on this repo. Lists doc paths, scripts, entrypoints, and integration hooks. No secrets.",
  "documentation": {
    "primary": "AGENTS.md",
    "numbered": [
      "docs/agent/01-architecture.md",
      "docs/agent/02-schemas.md",
      "docs/agent/03-github-actions.md",
      "docs/agent/04-theming.md",
      "docs/agent/05-github-models.md",
      "docs/agent/06-cursor-docs.md",
      "docs/agent/07-ai-notes.md",
      "docs/agent/08-local-ollama.md",
      "docs/agent/09-agent-collaboration.md",
      "docs/agent/10-colab-evolution.md"
    ],
    "human_readme": "README.md"
  },
  "package_manager": {
    "tool": "npm",
    "lockfile": "package-lock.json",
    "node": ">=20"
  },
  "scripts": {
    "install": "npm ci",
    "dev": "npm run dev",
    "lint": "npm run lint",
    "build": "npm run build",
    "preview": "npm run preview",
    "ollama_smoke": "npm run ollama:smoke"
  },
  "entrypoints": {
    "html": "index.html",
    "js": "src/main.tsx",
    "app": "src/App.tsx",
    "workspace_shell": "src/research/ResearchOverview.tsx",
    "summary_view": "src/Summary.tsx",
    "presentation_view": "src/Presentation.tsx"
  },
  "schemas": {
    "workspace_snapshot": {
      "ts_source": "src/research/workspace-snapshot.ts",
      "json_schema": "schemas/overview-workspace-snapshot.schema.json",
      "current_version": "2"
    },
    "research_types": "src/research/research-types.ts",
    "youtube_ingest_types": "src/research/youtube-ingest-types.ts"
  },
  "hooks": {
    "ai_iterate": {
      "file": "src/App.tsx",
      "symbol": "onAiIterate",
      "implementation": "src/ai/ollamaOpenAiIterate.ts:createOllamaOnAiIterate",
      "request_types": ["expand", "refine", "seed"],
      "request_type_def": "src/research/research-types.ts:AiIterateRequest"
    },
    "share_hash": {
      "encoder": "src/research/workspace-share-link.ts:encodeWorkspaceShare",
      "decoder": "src/research/workspace-share-link.ts:decodeWorkspaceSharePayload",
      "hash_prefix": "#workspace-share=",
      "max_url_chars": 8000
    },
    "dev_api": {
      "global": "window.__OVERVIEW_WORKSPACE__",
      "type": "src/research/workspace-snapshot.ts:OverviewWorkspaceDevApi",
      "snapshot_event": "overview-workspace-snapshot",
      "session_opt_in_key": "overview-workspace-bridge",
      "docs": "docs/agent/09-agent-collaboration.md"
    }
  },
  "ci": {
    "ci_workflow": ".github/workflows/ci.yml",
    "deploy_workflow": ".github/workflows/deploy-pages.yml",
    "models_smoke_workflow": ".github/workflows/models-smoke.yml"
  },
  "github_models": {
    "endpoint": "https://models.github.ai/inference",
    "auth": "Authorization: Bearer $GITHUB_TOKEN (server-side only)",
    "permission": "models: read",
    "client_side_safe": false,
    "example_script": "scripts/gh-models-example.sh",
    "docs": "docs/agent/05-github-models.md"
  },
  "env_vars": {
    "build_time": [
      "VITE_BASE_PATH",
      "VITE_DEFAULT_MODEL",
      "VITE_FFMPEG_STREAM_URL_TEMPLATE",
      "VITE_USE_AI_STUB",
      "VITE_OVERVIEW_CHAT_BASE",
      "VITE_OVERVIEW_CHAT_MODEL",
      "VITE_OVERVIEW_OPENAI_COMPAT_KEY",
      "VITE_FORCE_DIRECT_OLLAMA",
      "VITE_EXPOSE_WORKSPACE_API",
      "VITE_RELAY_HEXCAST_STREAM"
    ],
    "ci_only": ["GITHUB_TOKEN", "GITHUB_MODELS_ENDPOINT"],
    "scripts_only": ["GH_MODELS_MODEL"]
  },
  "fixtures": {
    "testv01_workspace_import": "fixtures/testv01-workspace.json"
  },
  "do_not_commit": [".env", ".env.*", "*.local", "node_modules/", "dist/"],
  "license": "see LICENSE if present"
}
